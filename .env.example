# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=node_app

# PostgreSQL superuser for local setup script (npm run setup)
# - Mac with Homebrew Postgres: use your OS username (e.g. john)
# - Linux / Windows: usually "postgres"
# Run `psql postgres -c "\du"` to list available superusers
DB_SUPERUSER=postgres
DB_SUPERUSER_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# Environment
NODE_ENV=development